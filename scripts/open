#! /bin/bash

__open() {
    open() {
        local target="$1"
        local as_name=""
        local t_env="$ENV"
        shift

        while [[ $# -gt 0 ]]; do
            case "$1" in
                --as=*)  as_name="${1#*=}" ;;
                --as)    as_name="$2"; shift ;;
                --env=*) t_env="${1#*=}" ;;
                --env)   t_env="$2"; shift ;;
            esac
            shift
        done

        [[ -z "$t_env" ]] && echo "Error: no env was set (use --env or export ENV)" >&2 && return 1
        
        if [[ -n "$as_name" ]]; then
            local cmd_data="$(__get open "$as_name" --env "$t_env")"
            if [[ $? -eq 0 ]]; then
                local cmd="$(echo "$cmd_data" | cut -d: -f3)"
                eval "$cmd \"$target\""
                return $?
            else
                return 1
            fi
        fi

        local target_mime=""
        [[ -f "$target" ]] && target_mime=$(file --brief --mime-type "$target")

        local config="$(__list open --env "$t_env")"
        IFS=',' read -ra ENTRIES <<< "$config"

        for entry in "${ENTRIES[@]}"; do
            [[ -z "$entry" ]] && continue
            local mime=$(echo "$entry" | cut -d: -f2)
            local ext=$(echo "$entry" | cut -d: -f3)
            local cmd=$(echo "$entry" | cut -d: -f4)

            if [[ -n "$mime" ]] && [[ -n "$target_mime" ]] && [[ "$target_mime" == $mime ]]; then
                eval "$cmd \"$target\"" && return 0
            elif [[ -n "$ext" ]] && [[ -f "$target" ]] && [[ "$target" == *."$ext" ]]; then
                eval "$cmd \"$target\"" && return 0
            fi
        done

        if [[ -n "$__OPEN" ]] && command -v "${__OPEN%% *}" >/dev/null 2>&1; then
            eval "$__OPEN \"$target\"" && return 0
        fi
        
        echo "Error: found no registered open kind for $target in env $t_env." >&2 && return 1
    }

    __open_compl() {
        local cur prev
        COMPREPLY=()
        cur="${COMP_WORDS[COMP_CWORD]}"
        prev="${COMP_WORDS[COMP_CWORD-1]}"

        if [[ "$prev" == "--env" ]]; then
            COMPREPLY=( $(compgen -W "${!ENVS[*]}" -- "$cur") )
            return 0
        fi
        
        if [[ "$prev" == "--as" ]]; then
            local current_env="${ENV:-$ENV_GLOBAL}"
            local opens="$(__list open --env "$current_env" 2>/dev/null)"
            if [[ -n "$opens" ]]; then
                COMPREPLY=( $(compgen -W "$(echo "$opens" | tr ',' '\n' | cut -d: -f1 | tr '\n' ' ')" -- "$cur") )
            fi
            return 0
        fi

        if [[ "$cur" == -* ]]; then
            COMPREPLY=( $(compgen -W "--as --env" -- "$cur") )
            return 0
        fi
    }

    __open_init() {
        __complete open
        __clean    open
    }
}
