#! /bin/bash

__comma() {
    comma() {
        local subcmd="$1"
        local alias_name="$2"
        shift 2

        local t_env="$ENV"
        local alias_path=""
        
        # Capture positional parameter for path if provided immediately
        if [[ "$subcmd" == "set" && $# -gt 0 && "$1" != -* ]]; then
            alias_path="$1"
            shift
        fi

        while [[ $# -gt 0 ]]; do
            case "$1" in
                --env=*)  t_env="${1#*=}" ;; --env) t_env="$2"; shift ;;
                --path=*) alias_path="${1#*=}" ;; --path) alias_path="$2"; shift ;;
            esac
            shift
        done

        [[ -z "$t_env" ]] && echo "Error: no env was set (use --env or export ENV)" >&2 && return 1

        if [[ "$subcmd" == "set" ]]; then
            [[ -z "$alias_path" ]] && echo "Error: path is mandatory for comma set" >&2 && return 1
            
            # Delegate state management to omni
            omni script comma set "$alias_name" --env "$t_env" --path "$alias_path"
            
        elif [[ "$subcmd" == "rm" ]]; then
            omni script comma rm "$alias_name" --env "$t_env"

        elif [[ "$subcmd" == "dot" ]]; then
            # Directly fetch the path using the new fast helper logic
            local found_path="$(__get comma "$alias_name" --env "$t_env")"
            if [[ $? -eq 0 && -n "$found_path" ]]; then
                dot "$found_path"
            else
                return 1
            fi
            
        else
            echo "Unknown comma command: $subcmd" >&2
            return 1
        fi
    }

    # Define Aliases
    alias ,="comma dot"
    alias ,a="comma set"
    alias ,d="comma rm"
}
