#! /bin/bash

__envs() {
    declare -Ag __ENV ENVS ENV_VARS ENV_LAZY ENV_OPEN ENV_COMMA ENV_SCRIPTS

    __compl_envs() {
        local cur prev cmd
        COMPREPLY=()
        cur="${COMP_WORDS[COMP_CWORD]}"
        prev="${COMP_WORDS[COMP_CWORD-1]}"

        if [[ "${COMP_WORDS[1]}" == "envs" ]]; then
            cmd="${COMP_WORDS[2]}"
        else
            cmd="${COMP_WORDS[1]}"
        fi

        if [[ "$prev" == "envs" ]]; then
            COMPREPLY=( $(compgen -W "ls set rm use --help" -- "$cur") )
            return 0
        fi

        if [[ "$prev" == "use" || "$prev" == "rm" ]]; then
            COMPREPLY=( $(compgen -W "${!ENVS[*]}" -- "$cur") )
            return 0
        fi

        if [[ "$cmd" == "set" && "$prev" != "set" && "$cur" == -* ]]; then
            COMPREPLY=( $(compgen -W "--path --bin --tmp --sec" -- "$cur") )
            return 0
        fi
    }
    complete -F __compl_envs envs

    envs() {
        local cmd="$1"
        case "$cmd" in
            ls)
                for e in "${!ENVS[@]}"; do echo "$e"; done
                ;;
            set)
                shift
                local name="$1"
                shift
                local path="" bin="" tmp=""
                
                while [[ $# -gt 0 ]]; do
                    case "$1" in
                        -p=*|--path=*) path="${1#*=}" ;;
                        -p|--path)     path="$2"; shift ;;
                        -b=*|--bin=*)  bin="${1#*=}" ;;
                        -b|--bin)      bin="$2"; shift ;;
                        -t=*|--tmp=*)  tmp="${1#*=}" ;;
                        -t|--tmp)      tmp="$2"; shift ;;
                        -s=*|--sec=*)  sec="${1#*=}" ;;
                        -s|--sec)      sec="$2"; shift ;;
                    esac
                    shift
                done
                
                [[ -z "$name" ]] && echo "Error: <env> is mandatory" >&2 && return 1
                [[ -z "$path" ]] && echo "Error: --path is mandatory" >&2 && return 1
                
                __update "ENVS" "$name" "$path" "set"
                __update "ENV_VARS" "$name" "path:$path,bin:$bin,tmp:$tmp,sec:$sec" "set"
                ;;
            rm)
                local name="$2"
                [[ -z "$name" ]] && echo "Error: <env> is mandatory" >&2 && return 1
                
                if ! __is env "$name"; then
                     echo "Error: '$name' is not a valid env" >&2; return 1
                fi
                
                [[ "$__ENV" == "$name" ]] && __envs_update_global_marker ""
                
                __update "ENVS" "$name" "" "rm"
                __update "ENV_VARS" "$name" "" "rm"
                __update "ENV_GLOBAL" "$name" "" "rm"
                __update "ENV_LAZY" "$name" "" "rm"
                __update "ENV_COMMA" "$name" "" "rm"
                __update "ENV_OPEN" "$name" "" "rm"
                __update "ENV_SCRIPTS" "$name" "" "rm"
                ;;
            use)
                local name="$2"
                local set_global=false
                if [[ "$3" == "-g" || "$3" == "--global" ]]; then set_global=true; fi
                
                [[ -z "$name" ]] && echo "Error: <env> is mandatory" >&2 && return 1
                
                if ! __is env "$name"; then
                     echo "Error: '$name' is not a valid env" >&2; return 1
                fi
                
                local env_path="${ENVS[$name]}"
                [[ -f "$env_path/init" ]] && source "$env_path/init"
                export ENV="$name"
                
                if $set_global; then
                     __envs_update_global_marker "$name"
                     export ENV_GLOBAL="$name"
                fi

                local scripts=$(__list scripts --env "$name" 2>/dev/null)
                if [[ -n "$scripts" ]]; then
                    for script in ${scripts//,/ }; do
                        source "$__OMNI_SCRIPTS/$script"
                        if declare -f "__${script}" > /dev/null; then
                            "__${script}"
                        fi
                    done
                fi
                ;; 
            --help|-h)
                echo "envs ls"
                echo "envs set <env> -p/--path=<path> -b/--bin=<bin_dir> -t/--tmp=<tmp_dir>"
                echo "envs rm <env>"
                echo "envs use <env> [-g/--global]"
                ;;
            *)
                echo "Unknown envs command: $cmd" >&2; return 1 ;;
        esac
    }
}                
