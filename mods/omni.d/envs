#! /bin/bash

__omni.envs__() {
    __omni__.envs.__help__() {
        echo """ABOUT:
    omni environments manager

USAGE:
    omni envs <command> [args]

COMMANDS:
    ls
    set     <env> -p/--path=<path> [-b/--bin=<bin>] [-t/--tmp=<tmp>] [-s/--sec=<sec>] [-m/--mnt=<mnt>]
    get     [<env>]
    rm      <env>
    use     <env> [-g/--global] [-b/--builtins=ls,cd...]""" >&2
    }

    __global() {
        local val="$1" rcfile="${OMNIRC:-${OMNI:-$HOME/.omni}/omnirc}"
        local content="" found=0

        if [[ -f "$rcfile" ]]; then
            while IFS= read -r line || [[ -n "$line" ]]; do
                if [[ "$line" == __ENV=* ]]; then
                    [[ -n "$val" ]] && content+="__ENV=\"$val\""$'\n'
                    found=1
                else
                    content+="$line"$'\n'
                fi
            done < "$rcfile"
        fi

        if [[ $found -eq 0 && -n "$val" ]]; then
            content+="__ENV=\"$val\""$'\n'
        fi

        if [[ -n "$content" || -f "$rcfile" ]]; then
            printf "%s" "$content" > "$rcfile"
        fi
    }

    __omni__.envs.init() {
        local t_env="${1:-$ENV}"
        local env_path=""
        
        if [[ -n "$t_env" && -n "${ENVS[$t_env]}" ]]; then
            env_path="${ENVS[$t_env]}"
        elif [[ -n "$ENV_PATH" ]]; then
            env_path="$ENV_PATH"
        fi
        
        [[ -z "$env_path" ]] && return 1
        
        if [[ -f "$env_path/init" ]]; then
            source "$env_path/init"
        else
            return 1
        fi
    }

    __omni__.envs.ls() { 
        for env in "${ENVS[@]}"; do echo "$env"; done
    }

    __omni__.envs.set() {
        local _target_name="$1"; shift
        local env_path="" bin="" tmp="" sec="" mnt=""
        while [[ $# -gt 0 ]]; do
            case "$1" in
                -p=*|--path=*) env_path="${1#*=}" ;;
                -p|--path)     env_path="$2"; shift ;;
                -b=*|--bin=*)  bin="${1#*=}" ;;
                -b|--bin)      bin="$2"; shift ;;
                -t=*|--tmp=*)  tmp="${1#*=}" ;;
                -t|--tmp)      tmp="$2"; shift ;;
                -s=*|--sec=*)  sec="${1#*=}" ;;
                -s|--sec)      sec="$2"; shift ;;
                -m=*|--mnt=*)  mnt="${1#*=}" ;;
                -m|--mnt)      mnt="$2"; shift ;;
            esac
            shift
        done
        [[ -z "$_target_name" ]] && return 1

        local base_env="${OMNI:-$HOME/.omni}/envs/$_target_name"
        [[ -z "$env_path" ]] && env_path="$base_env"
        [[ -z "$bin" ]]      && bin="$base_env/bin"
        [[ -z "$tmp" ]]      && tmp="$base_env/tmp"
        [[ -z "$sec" ]]      && sec="$base_env/sec"
        [[ -z "$mnt" ]]      && mnt="$base_env/mnt"

        local rcfile="${OMNIRC:-${OMNI:-$HOME/.omni}/omnirc}"
        if ! grep -q "ENVS+=($_target_name)" "$rcfile" 2>/dev/null; then
            echo "ENVS+=($_target_name)" >> "$rcfile"
        fi

        __update "ENV_VARS" "$_target_name" "path:$env_path,bin:$bin,tmp:$tmp,sec:$sec,mnt:$mnt" "set"
    }

    __omni__.envs.get() {
        local _target_name="${1:-$ENV}"
        [[ -z "$_target_name" ]] && return 1
        [[ -z "${ENVS[$_target_name]:-}" && "${ENVS[*]}" != *"$_target_name"* ]] && return 1
        local str=",${ENV_VARS[$_target_name]:-},"
        
        local e_path="${str#*,path:}"
        echo "ENV_PATH=${e_path%%,*}"
        local e_bin="${str#*,bin:}"
        echo "BIN=${e_bin%%,*}"
        local e_tmp="${str#*,tmp:}"
        echo "TMP=${e_tmp%%,*}"
        local e_sec="${str#*,sec:}"
        echo "SEC=${e_sec%%,*}"
        local e_mnt="${str#*,mnt:}"
        echo "MNT=${e_mnt%%,*}"
    }

    __omni__.envs.rm() {
        local _target_name="$1"
        [[ -z "$_target_name" ]] && return 1
        if ! __is env "$_target_name"; then return 1; fi
        [[ "${__ENV:-}" == "$_target_name" ]] && __global ""
        
        local rcfile="${OMNIRC:-${OMNI:-$HOME/.omni}/omnirc}"
        sed -i "/ENVS+=($_target_name)/d" "$rcfile" 2>/dev/null || true
        
        __update "ENVS" "$_target_name" "" "rm"
        __update "ENV_VARS" "$_target_name" "" "rm"
        __update "ENV_LAZY" "$_target_name" "" "rm"
        __update "ENV_COMMA" "$_target_name" "" "rm"
        __update "ENV_OPEN" "$_target_name" "" "rm"
        __update "ENV_PROVIDERS" "$_target_name" "" "rm"
        __update "ENV_TOOLS" "$_target_name" "" "rm"
        __update "ENV_CONTEXTS" "$_target_name" "" "rm"
    }

    __omni__.envs.use() {
        local _target_name="$1"
        if [[ -z "$_target_name" ]]; then _target_name="$ENV"; fi
        [[ -z "$_target_name" ]] && return 1
        shift
        local set_global=false b_list=""
        while [[ $# -gt 0 ]]; do
            case "$1" in
                -g|--global) set_global=true ;;
                -b=*|--builtins=*) b_list="${1#*=}" ;;
                -b|--builtins) b_list="$2"; shift ;;
            esac
            shift
        done
        if ! __is env "$_target_name"; then return 1; fi
        export ENV="$_target_name"
        local str=",${ENV_VARS[$_target_name]:-},"

        export ENV_PATH="${str#*,path:}" && export ENV_PATH="${ENV_PATH%%,*}"
        export BIN="${str#*,bin:}" && export BIN="${BIN%%,*}"
        export TMP="${str#*,tmp:}" && export TMP="${TMP%%,*}"
        export SEC="${str#*,sec:}" && export SEC="${SEC%%,*}"
        export MNT="${str#*,mnt:}" && export MNT="${MNT%%,*}"
        [[ -n "$BIN" ]] && export PATH="$PATH:$BIN"
        
        if $set_global; then __global "$_target_name"; export __ENV="$_target_name" __ENV_PATH="$ENV_PATH"; fi
        
        source "${OMNI:-$HOME/.omni}/mods/omni.d/builtins" 2>/dev/null || true
        if declare -f __omni.builtins__ >/dev/null 2>&1; then __omni.builtins__; fi
        
        if [[ -z "$b_list" ]]; then 
            if declare -f __omni__.builtins.__init__ >/dev/null 2>&1; then __omni__.builtins.__init__; fi
        else 
            for b in ${b_list//,/ }; do 
                if declare -f __omni__.builtins.use >/dev/null 2>&1; then __omni__.builtins.use "$b" -e "$_target_name"; fi
            done
        fi
        
        local active_tools="${ENV_TOOLS[$_target_name]:-}"
        if [[ -n "$active_tools" ]]; then
            local prov_dir="${OMNI:-$HOME/.omni}/providers"
            local OIFS="$IFS"
            IFS=','
            local entries=($active_tools)
            IFS="$OIFS"
            for entry in "${entries[@]}"; do
                if [[ -n "$entry" ]]; then
                    local p_name="builtins"
                    local t_name="$entry"
                    if [[ "$entry" == *"@@"* ]]; then
                        p_name="${entry%%@@*}"
                        t_name="${entry#*@@}"
                    fi
                    __load tool "$t_name" --from "$prov_dir/$p_name/tools" --lazy
                fi
            done
        fi

        local active_contexts="${ENV_CONTEXTS[$_target_name]:-}"
        if [[ -n "$active_contexts" ]]; then
            local prov_dir="${OMNI:-$HOME/.omni}/providers"
            local OIFS="$IFS"
            IFS=','
            local entries=($active_contexts)
            IFS="$OIFS"
            for entry in "${entries[@]}"; do
                if [[ -n "$entry" ]]; then
                    local p_name="builtins"
                    local c_name="$entry"
                    if [[ "$entry" == *"@@"* ]]; then
                        p_name="${entry%%@@*}"
                        c_name="${entry#*@@}"
                    fi
                    __load context "$c_name" --from "$prov_dir/$p_name/contexts" --lazy
                fi
            done
        fi
        
        if declare -f __init >/dev/null 2>&1; then
            if declare -f __omni__.builtins >/dev/null 2>&1; then __init __omni__.builtins; fi
        fi

        [[ -f "$ENV_PATH/init" ]] && source "$ENV_PATH/init"
    }

    __omni__.envs() {
        local cmd="$1"
        [[ -z "$cmd" || "$cmd" == "--help" || "$cmd" == "-h" ]] && { __omni__.envs.__help__; return 0; }
        shift

        case "$cmd" in
            init) __omni__.envs.init "$@" ;;
            ls)   __omni__.envs.ls   "$@" ;;
            set)  __omni__.envs.set  "$@" ;;
            rm)   __omni__.envs.rm   "$@" ;;
            get)  __omni__.envs.get  "$@" ;;
            use)  __omni__.envs.use  "$@" ;;
            *)    return 1 ;;
        esac
    }

    __omni__.envs.__compl__() {
        local cur="${COMP_WORDS[COMP_CWORD]}" prev="${COMP_WORDS[COMP_CWORD-1]}" base_cmd="${COMP_WORDS[1]:-}"
        if [[ "${COMP_CWORD}" == 1 ]]; then
            COMPREPLY=( $(compgen -W "ls get set rm use init --help -h" -- "$cur") )
            return 0
        fi
        local flags=""
        case "$base_cmd" in
            set) flags="--path --bin --tmp --sec --mnt" ;;
            use) flags="--global --builtins" ;;
        esac
        if [[ "$base_cmd" == "set" ]]; then
            COMPREPLY=( $(compgen -W "$flags" -- "$cur") )
            return 0
        fi
        if [[ "$base_cmd" == "use" || "$base_cmd" == "rm" || "$base_cmd" == "get" || "$base_cmd" == "init" ]]; then
            COMPREPLY=( $(compgen -W "${ENVS[*]} $flags" -- "$cur") )
            return 0
        fi
    }

    __omni__.envs.__init__() {
        __compl __omni__.envs
    }
}
