#! /bin/bash

__omni.run__() {

    __omni__.run.__help__() {
        echo """ABOUT:
    omni run execution wrapper

USAGE:
    run [-e|--env <env>] <string> (file or command)""" >&2
    }


    __omni__.run() {
        local target="" t_env=""
        
        if [[ -z "$1" || "$1" == "--help" || "$1" == "-h" ]]; then
            __omni__.run.__help__
            return 0
        fi

        while [[ $# -gt 0 ]]; do
            case "$1" in
                -e|--env) t_env="$2"; shift ;;
                --env=*)  t_env="${1#*=}" ;;
                *) 
                    if [[ -z "$target" ]]; then target="$1"
                    else target="$target $1"; fi
                    ;;
            esac
            shift
        done

        [[ -z "$target" ]] && __log "<string> (file or command) is mandatory" -t error -l run && return 1

        (
            if [[ -n "$t_env" && "$t_env" != "${ENV:-}" ]]; then
                envs use "$t_env" >/dev/null 2>&1
            fi

            if [[ -f "$target" ]]; then
                source "$target"
            else
                eval "$target"
            fi
        )
    }

    __omni__.run.__compl__() {
        local cur="${COMP_WORDS[COMP_CWORD]}"
        local prev="${COMP_WORDS[COMP_CWORD-1]}"

        if [[ "$prev" == "--env" ]]; then
            COMPREPLY=( $(compgen -W "${!ENVS[*]}" -- "$cur") )
            return 0
        fi
        
        local flags="--env"
        COMPREPLY=( $(compgen -W "$flags" -- "$cur") )
        compopt -o default
        return 0
    }  

    __omni__.run.__init__() {
        __compl __omni__.run
    }
}
