#! /bin/bash

__envs() {
    __envs_update_global_marker() {
        local val="$1"
        local rcfile="${__OMNIRC:-$HOME/.omnirc}"
        touch "$rcfile"
        
        if [[ -z "$val" ]]; then
            sed -i "/^__ENV=/d" "$rcfile"
        else
            if grep -q "^__ENV=" "$rcfile"; then
                sed -i "s|^__ENV=.*|__ENV=\"$val\"|" "$rcfile"
            else
                echo "__ENV=\"$val\"" >> "$rcfile"
            fi
        fi
    }

    envs() {
        local cmd="$1"
        case "$cmd" in
            ls)
                for e in "${!ENVS[@]}"; do echo "$e"; done
                ;;
            set)
                shift
                local name="$1"
                shift
                local env_path="" bin="" tmp=""
                while [[ $# -gt 0 ]]; do
                    case "$1" in
                        -p=*|--path=*) env_path="${1#*=}" ;;
                        -p|--path)     env_path="$2"; shift ;;
                        -b=*|--bin=*)  bin="${1#*=}" ;;
                        -b|--bin)      bin="$2"; shift ;;
                        -t=*|--tmp=*)  tmp="${1#*=}" ;;
                        -t|--tmp)      tmp="$2"; shift ;;
                        -s=*|--sec=*)  sec="${1#*=}" ;;
                        -s|--sec)      sec="$2"; shift ;;
                        -m=*|--mnt=*)  mnt="${1#*=}" ;;
                        -m|--mnt)      mnt="$2"; shift ;;
                    esac
                    shift
                done
                [[ -z "$name" ]] && __log "<env> is mandatory" -t error -l envs && return 1
                [[ -z "$env_path" ]] && __log "--path is mandatory" -t error -l envs && return 1
                __update "ENVS" "$name" "$env_path" "set"
                __update "ENV_VARS" "$name" "path:$env_path,bin:$bin,tmp:$tmp,sec:$sec,mnt:$mnt" "set"
                __log "Environment '$name' registered successfully." -t success -l envs
                ;;
            rm)
                local name="$2"
                [[ -z "$name" ]] && __log "<env> is mandatory" -t error -l envs && return 1
                if ! __is env "$name"; then
                     __log "'$name' is not a valid env" -t error -l envs;
                     return 1
                fi
                [[ "$__ENV" == "$name" ]] && __envs_update_global_marker ""
                __update "ENVS" "$name" "" "rm"
                __update "ENV_VARS" "$name" "" "rm"
                __update "ENV_LAZY" "$name" "" "rm"
                __update "ENV_COMMA" "$name" "" "rm"
                __update "ENV_OPEN" "$name" "" "rm"
                __update "ENV_SCRIPTS" "$name" "" "rm"
                __update "ENV_PROVIDERS" "$name" "" "rm"
                __update "ENV_TOOLS" "$name" "" "rm"
                __log "Environment '$name' removed." -t success -l envs
                ;;
            get)
                local name="${2:-$ENV}"
                [[ -z "$name" ]] && __log "<env> is mandatory" -t error -l envs && return 1
                [[ -z "${ENVS[$name]}" ]] && __log "env '$name' not registered" -t error -l envs && return 1
                local str=",${ENV_VARS[$name]},"
                local E_P="${str#*,path:}"
                E_P="${E_P%%,*}"
                local B="${str#*,bin:}"
                B="${B%%,*}"
                local T="${str#*,tmp:}"
                T="${T%%,*}"
                local S="${str#*,sec:}"
                S="${S%%,*}"
                local M="${str#*,mnt:}"
                M="${M%%,*}"                 
                echo "ENV_PATH=$E_P"
                echo "BIN=$B"
                echo "TMP=$T"
                echo "SEC=$S"
                echo "MNT=$M"
                ;;
            use)
                local name="$2"
                local set_global=false
                if [[ "$3" == "-g" || "$3" == "--global" ]]; then set_global=true; fi
                [[ -z "$name" ]] && __log "<env> is mandatory" -t error -l envs && return 1
                if ! __is env "$name"; then
                     __log "'$name' is not a valid env" -t error -l envs;
                     return 1
                fi
                local ENV_PATH_VAL="${ENVS[$name]}"
                [[ -f "$ENV_PATH_VAL/init" ]] && source "$ENV_PATH_VAL/init"
                export ENV="$name"
                export ENV_PATH="$ENV_PATH_VAL"
                local str=",${ENV_VARS[$name]},"
                local BIN_VAL="${str#*,bin:}"
                export BIN="${BIN_VAL%%,*}"
                local TMP_VAL="${str#*,tmp:}"
                export TMP="${TMP_VAL%%,*}"
                local SEC_VAL="${str#*,sec:}"
                export SEC="${SEC_VAL%%,*}"
                local MNT_VAL="${str#*,mnt:}"
                export MNT="${MNT_VAL%%,*}" 
                if [[ -n "$BIN" ]]; then
                    export PATH="$PATH:$BIN"
                fi
                if $set_global; then
                     __envs_update_global_marker "$name"
                     export __ENV="$name"
                     export __ENV_PATH="$ENV_PATH_VAL"
                fi
                local active_scripts=$(__list scripts --env "$name" 2>/dev/null)
                if [[ -n "$active_scripts" ]]; then
                    for script in ${active_scripts//,/ }; do
                        __load "$script" --from "$__OMNI_SCRIPTS/$script" --lazy
                    done
                fi
                local active_tools=$(__list tools --env "$name" 2>/dev/null)
                if [[ -n "$active_tools" ]]; then
                    for t_name in ${active_tools//,/ }; do
                        __load "$t_name" --from "$__OMNI_TOOLS/$t_name" --lazy
                    done
                fi
                ;;
            --help|-h)
                echo "envs ls"
                echo "envs set <env> -p/--path=<env_path> -b/--bin=<bin_path> -t/--tmp=<tmp_path>"
                echo "envs rm <env>"
                echo "envs use <env> [-g/--global]"
                ;;
            *)
                __log "Unknown envs command: $cmd" -t error -l envs;
                return 1 ;;
        esac
    } 
    __envs_compl() {
        local cur prev cmd
        COMPREPLY=()
        cur="${COMP_WORDS[COMP_CWORD]}"
        prev="${COMP_WORDS[COMP_CWORD-1]}"

        if [[ "${COMP_WORDS[1]}" == "envs" ]]; then cmd="${COMP_WORDS[2]}"; else cmd="${COMP_WORDS[1]}"; fi
        if [[ "$prev" == "envs" ]]; then COMPREPLY=( $(compgen -W "ls get set rm use --help" -- "$cur") ); return 0; fi
        if [[ "$prev" == "use" || "$prev" == "rm" ]]; then COMPREPLY=( $(compgen -W "${!ENVS[*]}" -- "$cur") ); return 0; fi
        if [[ "$cmd" == "set" && "$prev" != "set" && "$cur" == -* ]]; then COMPREPLY=( $(compgen -W "--path -p --bin -b --tmp -t" -- "$cur") ); return 0; fi
    }

    __envs_init() {
        __declare --dict ENVS ENV_VARS ENV_LAZY ENV_OPEN ENV_COMMA ENV_SCRIPTS PROVIDERS ENV_PROVIDERS TOOLS ENV_TOOLS IMPORTS CONTEXTS
        __complete envs
    }
}
