#! /bin/bash

__omni__() {
    __OMNI_COMMANDS="doc init builtins envs tools providers contexts run ssh"
    __omni__.__help__() {
        echo """ABOUT:
    the omnishell cli
USAGE:
    omni <command> [args]
COMMANDS:
    doc
    init
    builtins
    envs
    tools
    providers
    contexts
    run
    ssh
INFO:
    for custom help, try 'omni <command> --help'""" >&3
    }

    __omni__.init() {
        while [[ $# -gt 0 ]]; do
            case "$1" in
                -c|--conf) export OMNIRC="$2"; shift ;;
                --conf=*)  export OMNIRC="${1#*=}" ;;
            esac
            shift
        done
        local rcfile="${OMNIRC:-$HOME/.omnirc}"
        export OMNIRC="$rcfile"
        if [[ ! -f "$rcfile" ]]; then
            touch "$rcfile" 2>/dev/null
        fi
        if [[ -f "$rcfile" ]]; then
            source "$rcfile"
            declare -f __log >/dev/null && __log "Sourced $rcfile" -t success -l omni
        else
            declare -f __log >/dev/null && __log "Failed to create or access $rcfile" -t error -l omni || echo "omni: Failed to create or access $rcfile" >&2
            return 1
        fi
    }

    omni() {
        case "$1" in
            -c|--conf)
                (
                    export OMNIRC="$2"
                    unset ENV __ENV ENVS ENV_VARS ENV_LAZY ENV_OPEN ENV_COMMA PROVIDERS ENV_PROVIDERS TOOLS ENV_TOOLS IMPORTS CONTEXTS
                    declare -ga ENVS
                    declare -gA ENV_VARS ENV_LAZY ENV_OPEN ENV_COMMA PROVIDERS ENV_PROVIDERS TOOLS ENV_TOOLS IMPORTS CONTEXTS
                    [[ -f "$OMNIRC" ]] && source "$OMNIRC"
                    shift 2
                    [[ $# -eq 0 ]] && return 0
                    omni "$@"
                )
                return $?
                ;;
            --conf=*)
                (
                    export OMNIRC="${1#*=}"
                    unset ENV __ENV ENVS ENV_VARS ENV_LAZY ENV_OPEN ENV_COMMA PROVIDERS ENV_PROVIDERS TOOLS ENV_TOOLS IMPORTS CONTEXTS
                    declare -ga ENVS
                    declare -gA ENV_VARS ENV_LAZY ENV_OPEN ENV_COMMA PROVIDERS ENV_PROVIDERS TOOLS ENV_TOOLS IMPORTS CONTEXTS
                    [[ -f "$OMNIRC" ]] && source "$OMNIRC"
                    shift
                    [[ $# -eq 0 ]] && return 0
                    omni "$@"
                )
                return $?
                ;;
        esac

        local cmd="$1"
        [[ -z "$cmd" || "$cmd" == "--help" || "$cmd" == "-h" ]] && { __omni__.__help__; return 0; }
        shift

        case "$cmd" in
            doc)
                bash "$__OMNI/doc" --docs "$__OMNI/docs"
                ;;
            init)
                __omni__.init "$@"
                ;;
            builtins)
                declare -f __omni__.builtins >/dev/null 2>&1 || { source "$__OMNI_MODS/omni.d/builtins" && __omni.builtins__; }
                __omni__.builtins "$@"
                ;;
            envs)
                declare -f __omni__.envs >/dev/null 2>&1 || { source "$__OMNI_MODS/omni.d/envs" && __omni.envs__; }
                __omni__.envs "$@"
                ;;
            tools)
                declare -f __omni__.tools >/dev/null 2>&1 || { source "$__OMNI_MODS/omni.d/tools" && __omni.tools__; }
                __omni__.tools "$@"
                ;;
            providers)
                declare -f __omni__.providers >/dev/null 2>&1 || { source "$__OMNI_MODS/omni.d/providers" && __omni.providers__; }
                __omni__.providers "$@"
                ;;
            contexts)
                declare -f __omni__.contexts >/dev/null 2>&1 || { source "$__OMNI_MODS/omni.d/contexts" && __omni.contexts__; }
                __omni__.contexts "$@"
                ;;
            run)
                declare -f __omni__.run >/dev/null 2>&1 || { source "$__OMNI_MODS/omni.d/run" && __omni.run__; }
                __omni__.run "$@"
                ;;
            ssh)
                declare -f __omni__.ssh >/dev/null 2>&1 || { source "$__OMNI_MODS/omni.d/ssh" && __omni.ssh__; }
                __omni__.ssh "$@"
                ;;
            *)
                declare -f __log >/dev/null && __log "Unknown command '$cmd' for omni" -t error -l "omni" || echo "omni: Unknown command '$cmd'" >&2
                return 1
                ;;
        esac
    }

    __omni__.__compl__() {
        local cur="${COMP_WORDS[COMP_CWORD]}" prev="${COMP_WORDS[COMP_CWORD-1]}"
        local cmd_idx=1

        if [[ "${COMP_WORDS[1]}" == "-c" || "${COMP_WORDS[1]}" == "--conf" ]]; then
            cmd_idx=3
        elif [[ "${COMP_WORDS[1]}" == "--conf="* ]]; then
            cmd_idx=2
        fi

        if [[ ${COMP_CWORD} -eq 1 ]]; then
            if [[ "$cur" == -* ]]; then
                COMPREPLY=( $(compgen -W "--conf" -- "$cur") )
            else
                COMPREPLY=( $(compgen -W "$__OMNI_COMMANDS --conf" -- "$cur") )
            fi
            return 0
        fi

        if [[ "$prev" == "-c" || "$prev" == "--conf" ]] && [[ ${COMP_CWORD} -eq 2 && $cmd_idx -eq 3 ]]; then
            compopt -o default
            return 0
        fi

        if [[ ${COMP_CWORD} -eq $cmd_idx ]]; then
            COMPREPLY=( $(compgen -W "$__OMNI_COMMANDS" -- "$cur") )
            return 0
        fi

        local cmd="${COMP_WORDS[cmd_idx]}"
        if [[ "$cmd" == "init" ]]; then
            if [[ "$prev" == "-c" || "$prev" == "--conf" ]]; then
                compopt -o default
                return 0
            fi
            COMPREPLY=( $(compgen -W "--conf" -- "$cur") )
            return 0
        fi

        if [[ " $__OMNI_COMMANDS " == *" $cmd "* && "$cmd" != "init" ]]; then
            local __cmd__="__omni__.${cmd}"
            local __compl__="${__cmd__}.__compl__"

            if ! declare -f "${__compl__}" >/dev/null 2>&1; then
                source "$__OMNI_MODS/omni.d/$cmd" 2>/dev/null
                "__omni.${cmd}__" 2>/dev/null || true
                "${__cmd__}.__init__" 2>/dev/null || true
            fi

            if declare -f "${__compl__}" >/dev/null 2>&1; then
                local -a COMP_WORDS_BACKUP=("${COMP_WORDS[@]}")
                local COMP_CWORD_BACKUP=$COMP_CWORD
                COMP_WORDS=( "${COMP_WORDS[@]:$cmd_idx}" )
                COMP_CWORD=$((COMP_CWORD - cmd_idx))
                "${__compl__}"
                COMP_WORDS=("${COMP_WORDS_BACKUP[@]}")
                COMP_CWORD=$COMP_CWORD_BACKUP
            fi
        fi
    }

    __omni__.__init__() {
        local scripts=("$__OMNI_MODS/omni.d/*")
        local script name

        for script in ${scripts[@]}; do
            source "$script"
            name="$(basename "$script")"

            if declare -f "__omni.${name}__" > /dev/null 2>&1; then
                "__omni.${name}__" >/dev/null 2>&1
                unset -f "__omni.${name}__"
            fi
        done

        complete -o default -o bashdefault -F __omni__.__compl__ omni
    }

    __omni__.__init__
}
