#! /bin/bash

__omni__() {
    __OMNI_COMMANDS="init builtins envs tools providers contexts run"

    __omni__.__help__() {
        echo """ABOUT:
    the omnishell cli

USAGE:
    omni <command> [args]

COMMANDS:
    init
    builtins
    envs
    tools
    providers
    contexts
    run

INFO:
    for custom help, try 'omni <command> --help'""" >&2
    }

    __omni__.init() {
        while [[ $# -gt 0 ]]; do
            case "$1" in
                -c|--conf) export __OMNIRC="$2"; shift ;;
                --conf=*)  export __OMNIRC="${1#*=}" ;;
            esac
            shift
        done

        local rcfile="${__OMNIRC:-$HOME/.omnirc}"
        export __OMNIRC="$rcfile"

        if [[ ! -f "$rcfile" ]]; then
            touch "$rcfile" 2>/dev/null
        fi

        if [[ -f "$rcfile" ]]; then
            source "$rcfile"
            declare -f __log >/dev/null && __log "Sourced $rcfile" -t success -l omni
        else
            declare -f __log >/dev/null && __log "Failed to create or access $rcfile" -t error -l omni || echo "omni: Failed to create or access $rcfile" >&2
            return 1
        fi
    }

    __omni__.__compl__() {
        local cur="${COMP_WORDS[COMP_CWORD]}"
        if [[ "${COMP_CWORD}" == 1 ]]; then
            COMPREPLY=( $(compgen -W "$__OMNI_COMMANDS" -- "$cur") )
            return 0
        fi

        local cmd="${COMP_WORDS[1]}"
        
        if [[ "$cmd" == "init" ]]; then
            local prev="${COMP_WORDS[COMP_CWORD-1]}"
            if [[ "$prev" == "-c" || "$prev" == "--conf" ]]; then
                compopt -o default
                return 0
            fi
            COMPREPLY=( $(compgen -W "--conf" -- "$cur") )
            return 0
        fi

        if [[ " $__OMNI_COMMANDS " == *" $cmd "* && "$cmd" != "init" ]]; then
            local __cmd__="__omni__.${cmd}"
            local __compl__="${__cmd__}.__compl__"
            
            if ! declare -f "${__compl__}" >/dev/null 2>&1; then
                source "$__OMNI_MODS/$cmd" 2>/dev/null
                "__omni.${cmd}__" 2>/dev/null || true
                "${__cmd__}.__init__" 2>/dev/null || true
            fi
            
            if declare -f "${__compl__}" >/dev/null 2>&1; then
                local -a COMP_WORDS_BACKUP=("${COMP_WORDS[@]}")
                local COMP_CWORDs_BACKUP=$COMP_CWORD

                COMP_WORDS=( "${COMP_WORDS[@]:1}" )
                ((COMP_CWORD--))

                "${__compl__}"

                COMP_WORDS=("${COMP_WORDS_BACKUP[@]}")
                COMP_CWORD=$COMP_CWORD_BACKUP
            fi
        fi
    } 
    __omni__.__init__() {
        local scripts=("$__OMNI_MODS/omni.d/*")
        for script in ${scripts[@]}; do
            source $script
            name=$(basename $script)
            if declare -f "__omni.${name}__" > /dev/null 2>&1; then eval "__omni.${name}__" /dev/null 2>&1; fi
            __clean __omni__.$name
        done
        complete -o default -o bashdefault -F __omni__.__compl__ omni
    }

    __build omni \
        init=__omni__.init \
        builtins=__omni__.builtins   --from "$__OMNI_MODS/omni.d/builtins" \
        envs=__omni__.envs           --from "$__OMNI_MODS/omni.d/envs" \
        tools=__omni__.tools         --from "$__OMNI_MODS/omni.d/tools" \
        providers=__omni__.providers --from "$__OMNI_MODS/omni.d/providers" \
        contexts=__omni__.contexts   --from "$__OMNI_MODS/omni.d/contexts" \
        run=__omni__.run             --from "$__OMNI_MODS/omni.d/run"

    __omni__.__init__
}
