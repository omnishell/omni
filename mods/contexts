#! /bin/bash

__contexts() {
    contexts() {
        local cmd="$1"
        case "$cmd" in
            ls)
                local t_env="" is_all=0
                shift
                while [[ $# -gt 0 ]]; do
                    case "$1" in 
                        -e|--env) t_env="$2"; shift ;;
                        -a|--all) is_all=1 ;;
                    esac
                    shift
                done
                
                local available=()
                local contexts_dir="${__OMNI_CONTEXTS:-$__OMNI/contexts}"
                
                if [[ -d "$contexts_dir" ]]; then
                    for f in "$contexts_dir"/*; do
                        [[ -f "$f" ]] && available+=("$(basename "$f")")
                    done
                fi
                
                for c in "${!CONTEXTS[@]}"; do
                    if [[ -n "${CONTEXTS[$c]}" || -f "$contexts_dir/$c" ]]; then
                        available+=("$c")
                    fi
                done
                
                if (( is_all )); then
                    printf "%s\n" "${available[@]}" | sort -u | grep -v '^$'
                else
                    [[ -z "$t_env" ]] && t_env="$ENV"
                    [[ -z "$t_env" ]] && __log "no env was set" -t error -l contexts && return 1
                    
                    local env_tools="${ENV_TOOLS[$t_env]:-}"
                    local filtered=()
                    
                    for c in "${available[@]}"; do
                        if [[ -f "$contexts_dir/$c" ]] || [[ ",${env_tools}," == *",${c},"* ]]; then
                            filtered+=("$c")
                        fi
                    done
                    printf "%s\n" "${filtered[@]}" | sort -u | grep -v '^$'
                fi
                ;;
            get)
                local ctx="$2" attr="$3"
                [[ -z "$ctx" ]] && __log "context is mandatory" -t error -l contexts && return 1
                
                local attrs="$(__attrs "$ctx" | tr ' ' ',')"
                
                if [[ -n "$attrs" && "$attrs" != "," ]]; then
                    if [[ -z "$attr" ]]; then
                        echo "$attrs" | tr ',' '\n'
                    else
                        local search=",${attrs},"
                        if [[ "$search" == *",${attr},"* ]]; then
                            echo "${ctx}.${attr}"
                        else
                            __log "Attribute '$attr' not found in context '$ctx'." -t error -l contexts
                            return 1
                        fi
                    fi
                else
                    __log "Context '$ctx' not found or has no attributes." -t error -l contexts
                    return 1
                fi
                ;;
            *) __log "Unknown contexts command: $cmd" -t error -l contexts; return 1 ;;
        esac
    }

    __contexts_compl() {
        local cur prev base_cmd
        COMPREPLY=()
        cur="${COMP_WORDS[COMP_CWORD]}"
        prev="${COMP_WORDS[COMP_CWORD-1]}"
        base_cmd="${COMP_WORDS[1]}"

        if [[ "${COMP_CWORD}" == 1 ]]; then COMPREPLY=( $(compgen -W "ls get" -- "$cur") ); return 0; fi
        
        if [[ "$prev" == "get" ]]; then 
            local ctxs="$(contexts ls -a 2>/dev/null)"
            COMPREPLY=( $(compgen -W "$ctxs" -- "$cur") )
            return 0
        fi
        
        if [[ "$base_cmd" == "get" && "${COMP_CWORD}" == 3 ]]; then
            local ctx="$prev"
            local attrs="$(__attrs "$ctx")"
            COMPREPLY=( $(compgen -W "$attrs" -- "$cur") )
            return 0
        fi

        if [[ "$base_cmd" == "ls" && "$cur" == -* ]]; then COMPREPLY=( $(compgen -W "--env -e --all -a" -- "$cur") ); return 0; fi
        if [[ "$prev" == "--env" || "$prev" == "-e" ]]; then COMPREPLY=( $(compgen -W "${!ENVS[*]}" -- "$cur") ); return 0; fi
    }

    __contexts_init() {
        __complete contexts
    }
}
