#! /bin/bash

__init__() {
    export __OMNI_SH=$__OMNI/sh
    export __OMNI_CONF=$__OMNI/conf
    export __OMNI_SCRIPTS=$__OMNI/scripts

    export __OMNIRC="${__OMNIRC:-$HOME/.omnirc}"

    export SCRIPTS=$(shopt -s nullglob; files=("$__OMNI_SCRIPTS"/*); files=("${files[@]##*/}"); IFS=,; echo "${files[*]}")

    for mod in builtins helper envs scripts omni custom; do
        if [[ -f "$__OMNI_SH/$mod" ]]; then
            source "$__OMNI_SH/$mod"
            if declare -f "__${mod}" > /dev/null; then
                "__${mod}"
                if declare -f "__${mod}_init" > /dev/null; then
                    "__${mod}_init"
                fi
                unset -f "__${mod}" "__${mod}_init" "__${mod}_aliases" 2>/dev/null || true
            fi
        fi
    done

    [[ -f "$__OMNIRC" ]] && source "$__OMNIRC"

    export ENV="${ENV:-$__ENV}"
    if [[ -n "$ENV" ]]; then
        envs use "$ENV"
    fi
}

__init__
unset -f __init__
