#! /bin/bash

__init__() {
    export __OMNI_MODS=$__OMNI/mods
    export __OMNI_CONF=$__OMNI/conf
    export __OMNI_SCRIPTS=$__OMNI/scripts
    export __OMNI_TOOLS=$__OMNI/tools
    export __OMNI_CONTEXTS=$__OMNI/contexts

    mkdir -p "$__OMNI_SCRIPTS" "$__OMNI_TOOLS" 2>/dev/null || true
    export __OMNIRC="${__OMNIRC:-$HOME/.omnirc}"

    source "$__OMNI_MODS/helper" && __helper

    for mod in helper builtins; do
        __load "$mod" --from "$__OMNI_MODS/$mod"
    done

    for mod in envs scripts tools providers contexts run omni custom; do 
        __load "$mod" --from "$__OMNI_MODS/$mod" --lazy
    done

    [[ -f "$__OMNIRC" ]] && source "$__OMNIRC"
    export SCRIPTS=$(shopt -s nullglob; files=("$__OMNI_SCRIPTS"/*); files=("${files[@]##*/}"); IFS=,; echo "${files[*]}")

    export ENV="${ENV:-$__ENV}"
    if [[ -n "$ENV" ]]; then
        envs use "$ENV"
    fi
}

__init__
unset -f __init__
