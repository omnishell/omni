#! /bin/bash

__open__() {
    __open__.__help__() {
        echo """ABOUT:
    omni custom file opener

USAGE:
    open ls
    open set <kind> -c <cmd>
    open rm <kind>
    open <target>
    open -- <target>

FLAGS:
  -h, --help    Show this help""" >&2
    }

    open() {
        local cmd="$1"
        local is_explicit=0

        if [[ "$cmd" == "--" ]]; then
            is_explicit=1
            shift
            cmd="$1"
        fi
        
        if (( ! is_explicit )); then
            if [[ "$cmd" == "--help" || "$cmd" == "-h" ]]; then
                __open__.__help__
                return 0
            fi
            
            case "$cmd" in
                ls)
                    shift
                    local t_env="$ENV"
                    while [[ $# -gt 0 ]]; do case "$1" in --env|-e) t_env="$2"; shift ;; esac; shift; done
                    [[ -z "$t_env" ]] && __log "no env was set" -t error -l open && return 1
                    echo "${ENV_OPEN[$t_env]}" | tr ',' '\n' | grep -v '^$'
                    return 0
                    ;;
                set)
                    shift
                    local kind="$1"
                    shift
                    local open_cmd="" t_env="$ENV"
                    
                    while [[ $# -gt 0 ]]; do
                        case "$1" in
                            --command=*) open_cmd="${1#*=}" ;;
                            --command|-c) open_cmd="$2"; shift ;;
                            --env|-e) t_env="$2"; shift ;;
                        esac
                        shift
                    done
                    
                    [[ -z "$kind" ]] && __log "<kind> is mandatory (use '*' for default)" -t error -l open && return 1
                    [[ -z "$open_cmd" ]] && __log "--command is mandatory" -t error -l open && return 1
                    [[ -z "$t_env" ]] && __log "no env was set" -t error -l open && return 1
                    
                    local current="${ENV_OPEN[$t_env]}"
                    local new_val=$(echo ",${current}" | sed -E "s/,${kind//\*/\\*}:[^,]*/,/g" | sed "s/^,//")
                    new_val="${new_val}${kind}:${open_cmd},"
                    
                    __update "ENV_OPEN" "$t_env" "$new_val" "set"
                    __log "Registered '$kind' -> '$open_cmd' in env '$t_env'." -t success -l open
                    return 0
                    ;;
                rm)
                    shift
                    local kind="$1"
                    shift
                    local t_env="$ENV"
                    
                    while [[ $# -gt 0 ]]; do case "$1" in --env|-e) t_env="$2"; shift ;; esac; shift; done
                    
                    [[ -z "$kind" ]] && __log "<kind> is mandatory" -t error -l open && return 1
                    [[ -z "$t_env" ]] && __log "no env was set" -t error -l open && return 1
                    
                    local current="${ENV_OPEN[$t_env]}"
                    local new_val=$(echo ",${current}" | sed -E "s/,${kind//\*/\\*}:[^,]*/,/g" | sed "s/^,//")
                    
                    __update "ENV_OPEN" "$t_env" "$new_val" "set"
                    __log "Removed '$kind' from env '$t_env'." -t success -l open
                    return 0
                    ;;
            esac
        fi
        
        local target="$1"
        [[ -z "$target" ]] && open --help && return 1
        
        shift
        local t_env="$ENV"
        
        [[ -z "$t_env" ]] && __log "no env was set" -t error -l open && return 1
        
        local current="${ENV_OPEN[$t_env]}"
        local kind=""
        
        if [[ -d "$target" ]]; then
            kind="/"
        else
            kind="${target##*.}"
            [[ "$kind" == "$target" ]] && kind="*" 
        fi
        
        local extract=",${current}"
        extract="${extract##*,${kind}:}"
        local open_cmd="${extract%%,*}"
        
        if [[ -z "$open_cmd" || "$open_cmd" == ",${current}" ]]; then
            extract=",${current}"
            extract="${extract##*,\*:}"
            open_cmd="${extract%%,*}"
            
            if [[ -z "$open_cmd" || "$open_cmd" == ",${current}" ]]; then
                __log "found no registered open kind for '$target' in env '$t_env'." -t error -l open
                return 1
            fi
        fi
        
        eval "$open_cmd \"\$target\" \"\$@\""
    }

    __open__.__compl__() {
        local cur prev base_cmd
        COMPREPLY=()
        cur="${COMP_WORDS[COMP_CWORD]}"
        prev="${COMP_WORDS[COMP_CWORD-1]}"
        base_cmd="${COMP_WORDS[1]}"

        if [[ "${COMP_CWORD}" == 1 ]]; then
            COMPREPLY=( $(compgen -W "ls set rm --help --" -- "$cur") )
            compopt -o default 
            return 0
        fi

        if [[ "$prev" == "set" || "$prev" == "rm" ]]; then
            local current="${ENV_OPEN[$ENV]}"
            local keys=$(echo "$current" | grep -oE '[^,]+:' | tr -d ':')
            COMPREPLY=( $(compgen -W "* / $keys" -- "$cur") )
            return 0
        fi

        if [[ "$base_cmd" == "set" && "$cur" == -* ]]; then COMPREPLY=( $(compgen -W "--command -c --env -e" -- "$cur") ); return 0; fi
        if [[ "$prev" == "--env" || "$prev" == "-e" ]]; then COMPREPLY=( $(compgen -W "${!ENVS[*]}" -- "$cur") ); return 0; fi
    }

    __open__.__init__() {
        __compl open
    }
}
